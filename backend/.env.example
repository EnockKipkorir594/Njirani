#List of environment variables Njirani needs for the backend 

#Postgres connection 
DATABASE_URL=postgresql://janedoe:mypassword@localhost:5432/mydb

#Redis connection 
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

#JWT secret key 
JWT_SECRET=your-256-bit-secret

#Email credentials 
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-password

#SMS credentials 
SMS_API_KEY=your-api-key
SMS_API_SECRET=your-api-secret
SMS_API_URL=https://api.africastalking.com/version1/messaging

#Africas talking credentials 
AT_USERNAME=your-username
AT_API_KEY=your-api-key

#BullMQ connection 
BULLMQ_CONNECTION_URL=redis://localhost:6379

#Port number and environment variables 
PORT=3000
NODE_ENV=development

#Paystack credentials 
DARAJA_API_KEY=your-api-key
DARAJA_API_SECRET=your-api-secret
DARAJA_API_URL=https://api.paystack.co

#Anthropic credentials 
ANTHROPIC_API_KEY=your-api-key
ANTHROPIC_API_URL=https://api.anthropic.com/v1
